{
  "name": "edumailai",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "WATCHPACK_POLLING=true next dev --webpack --hostname 127.0.0.1",
    "dev:webpack": "WATCHPACK_POLLING=true next dev --webpack --hostname 127.0.0.1",
    "build": "next build --webpack",
    "build:json-file": "node scripts/build-json-file.mjs",
    "build:database": "node scripts/build-database.mjs",
    "build:sqlite": "node scripts/build-sqlite.mjs",
    "start": "next start --hostname 127.0.0.1",
    "lint": "node scripts/basic-lint.mjs",
    "lint:eslint": "eslint app components lib eslint.config.mjs next.config.ts postcss.config.mjs",
    "check:architecture": "node scripts/check-architecture.mjs",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "verify": "npm run lint && npm run lint:eslint && npm run check:architecture && npm run typecheck && npm run build",
    "verify:adapter-modes": "npm run verify && npm run build:json-file && npm run build:sqlite && npm run build:database"
  },
  "dependencies": {
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

EDUMAILAI_MAILBOX_ADAPTER=local
EDUMAILAI_KNOWLEDGE_BASE_ADAPTER=local
EDUMAILAI_ACTIVITY_ADAPTER=local
EDUMAILAI_AI_DRAFT_ADAPTER=local
EDUMAILAI_WORKSPACE_SETTINGS_ADAPTER=local
EDUMAILAI_FILE_STORAGE_ADAPTER=local
EDUMAILAI_AUTH_PROVIDER=supabase_auth

# Supported now:
# - local: demo-friendly bootstrapped mode with seeded fallback data
# - json_file: persisted-record mode without seeded fallback for mailbox/activity/KB
# - sqlite: sqlite-backed persisted mode for mailbox/activity/KB metadata
# - database: generic database adapter mode driven by EDUMAILAI_DATABASE_URL
#   (supports sqlite/file paths and PostgreSQL connection strings, including Supabase)
# - supabase_storage: Supabase Storage-backed file adapter for knowledge-base binaries
#
# Future provider configuration examples. Keep them empty until real platforms
# are chosen and implemented behind the adapter layer.
# EDUMAILAI_SQLITE_PATH=
# EDUMAILAI_DATABASE_URL=sqlite:edumailai.database.sqlite
# EDUMAILAI_DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require
# EDUMAILAI_DATABASE_SSL_MODE=require
# EDUMAILAI_FILE_STORAGE_BUCKET=
# EDUMAILAI_SUPABASE_URL=https://[project-ref].supabase.co
# EDUMAILAI_SUPABASE_SERVICE_KEY=sb_secret_...
# NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Supabase Auth redirect URLs:
# http://127.0.0.1:3000/auth/callback
# http://localhost:3000/auth/callback
# EDUMAILAI_FILE_STORAGE_ADAPTER=supabase_storage
# EDUMAILAI_AI_API_KEY=
# EDUMAILAI_INBOX_PROVIDER=
# EDUMAILAI_HOSTING_PROVIDER=
# EDUMAILAI_OBSERVABILITY_PROVIDER=
